
###

POST http://localhost:4020/graphql
Content-Type: application/json

{
  "query": "mutation($input: CreateOrderInput!) { createOrder(input: $input) { id userId status totalAmount items { productId quantity price } } }",
  "variables": {
    "input": {
      "userId": "1",
      "items": [
        {
          "productId": "1",
          "quantity": 2,
          "price": 10.5
        }
      ]
    }
  }
}

